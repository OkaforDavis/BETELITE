# BETELITE ENVIRONMENT CONFIGURATION
# ====================================
# Copy to .env and configure for your environment
# ZERO_TRUST: Never log sensitive values

# Database (MySQL 8+, Strict mode enabled)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=betelite_db
DB_USER=betelite_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_CHARSET=utf8mb4
DB_STRICT_MODE=true

# Application
APP_NAME=BETELITE
APP_ENV=production
APP_DEBUG=false
APP_URL=https://betelite.example.com

# Security - CORE_LOCK: Never expose in logs
SESSION_TIMEOUT=3600
SESSION_SECURE_COOKIE=true
SESSION_HTTPONLY=true
SESSION_SAMESITE=Strict
CSRF_TOKEN_LENGTH=32

# JWT/Token Settings
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRY=86400

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600
IP_THROTTLE_ENABLED=true
IP_THROTTLE_ATTEMPTS=5
IP_THROTTLE_LOCKOUT=900

# Logging - AUDIT_TRACE: All financial/security events
LOG_LEVEL=info
LOG_FILE=logs/betelite.log
AUDIT_LOG_FILE=logs/audit.log
ERROR_LOG_FILE=logs/errors.log

# Email Configuration
MAIL_DRIVER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=noreply@betelite.example.com
MAIL_PASSWORD=CHANGE_ME
MAIL_FROM_NAME=BETELITE

# Payment Gateway - SAFE_SWAP: Pluggable integrations
PAYMENT_PROVIDER=paystack
PAYSTACK_PUBLIC_KEY=pk_live_xxx
PAYSTACK_SECRET_KEY=sk_live_xxx
PAYSTACK_VERIFY_URL=https://api.paystack.co/transaction/verify

FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_LIVE_xxx
FLUTTERWAVE_SECRET_KEY=FLWSECK_LIVE_xxx
FLUTTERWAVE_ENCRYPTION_KEY=xxx

# Wallet & Escrow - CORE_LOCK: Critical financial logic
ESCROW_ENABLED=true
MIN_WITHDRAWAL=1000
MAX_WITHDRAWAL=1000000
WITHDRAWAL_FEE_PERCENT=0.5
WALLET_PRECISION=2

# Streaming - SAFE_SWAP: Pluggable providers
STREAMING_PROVIDER=cloudflare
CLOUDFLARE_ACCOUNT_ID=xxx
CLOUDFLARE_AUTH_TOKEN=xxx
CLOUDFLARE_STREAM_API_URL=https://api.cloudflare.com/client/v4/accounts/{account_id}/stream

MUX_ACCESS_TOKEN=xxx
MUX_API_URL=https://api.mux.com

# Betting Engine
BETTING_ENABLED=false
MIN_BET_AMOUNT=100
MAX_BET_AMOUNT=100000
MAX_BET_RATIO=0.5
ODDS_PRECISION=2

# Geo-blocking
GEO_BLOCKING_ENABLED=false
BLOCKED_COUNTRIES=NG,KE
ALLOWED_COUNTRIES=

# Age Verification (KYC)
KYC_ENABLED=false
MIN_AGE=18

# Admin Settings
ADMIN_EMAIL=admin@betelite.example.com
ADMIN_PHONE=+1234567890

# Security Headers
ALLOW_CROSS_ORIGIN=false
CORS_ORIGINS=https://betelite.example.com

# File Upload
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=5242880
ALLOWED_UPLOAD_TYPES=jpg,jpeg,png,gif,pdf
