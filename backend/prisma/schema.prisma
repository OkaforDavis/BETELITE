generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            BigInt    @id @default(autoincrement()) @map("user_id")
  username      String    @unique @db.VarChar(50)
  email         String    @unique @db.VarChar(255)
  passwordHash  String    @map("password_hash") @db.VarChar(255)
  userType      UserType  @default(player) @map("user_type")
  accountStatus AccountStatus @default(pending_verification) @map("account_status")
  emailVerified Boolean   @default(false) @map("email_verified")
  kycVerified   Boolean   @default(false) @map("kyc_verified")
  mfaEnabled    Boolean   @default(false) @map("mfa_enabled")
  mfaSecret     String?   @map("mfa_secret") @db.VarChar(255)
  countryCode   String?   @map("country_code") @db.Char(2)
  dateOfBirth   DateTime? @map("date_of_birth") @db.Date
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  lastLogin     DateTime? @map("last_login") @db.Timestamp(0)

  profile             UserProfile?
  sessions            UserSession[]
  ownedTeams          Team[]               @relation("TeamOwner")
  teamMemberships     TeamMember[]
  organizedTournaments Tournament[]
  soloParticipations  TournamentParticipant[] @relation("SoloParticipant")
  wallet              Wallet?
  bets                Bet[]
  streams             Stream[]
  chatMessages        StreamChat[]
  reportedDisputes    MatchDispute[]       @relation("DisputeReporter")
  resolvedDisputes    MatchDispute[]       @relation("DisputeResolver")
  refereedMatches     Match[]              @relation("MatchReferee")
  auditLogs           AuditLog[]
  securityEvents      SecurityEvent[]
  createdTransactions WalletTransaction[]  @relation("TransactionCreator")
  settingsUpdates     SystemSetting[]
  deletedChats        StreamChat[]         @relation("ChatDeleter")

  @@index([email])
  @@index([username])
  @@index([accountStatus])
  @@index([userType])
  @@map("users")
}

model UserProfile {
  profileId       BigInt    @id @default(autoincrement()) @map("profile_id")
  userId          BigInt    @unique @map("user_id")
  displayName     String?   @map("display_name") @db.VarChar(100)
  avatarUrl       String?   @map("avatar_url") @db.VarChar(500)
  bio             String?   @db.Text
  timezone        String    @default("UTC") @db.VarChar(50)
  preferredGames  Json?     @map("preferred_games")
  socialLinks     Json?     @map("social_links")
  privacySettings Json?     @map("privacy_settings")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model UserSession {
  sessionId    String   @id @map("session_id") @db.VarChar(128)
  userId       BigInt   @map("user_id")
  ipAddress    String   @map("ip_address") @db.VarChar(45)
  userAgent    String   @map("user_agent") @db.Text
  csrfToken    String   @map("csrf_token") @db.VarChar(64)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  expiresAt    DateTime @map("expires_at") @db.Timestamp(0)
  lastActivity DateTime @default(now()) @updatedAt @map("last_activity") @db.Timestamp(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("user_sessions")
}

model Game {
  gameId       Int      @id @default(autoincrement()) @map("game_id")
  gameName     String   @unique @map("game_name") @db.VarChar(100)
  gameCode     String   @unique @map("game_code") @db.VarChar(20)
  gameCategory GameCategory @map("game_category")
  isActive     Boolean  @default(true) @map("is_active")
  supportsTeams Boolean @default(true) @map("supports_teams")
  maxTeamSize  Int      @default(1) @map("max_team_size")
  iconUrl      String?  @map("icon_url") @db.VarChar(500)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  teams       Team[]
  tournaments Tournament[]

  @@index([gameCode])
  @@index([isActive])
  @@map("games")
}

model Team {
  teamId     BigInt     @id @default(autoincrement()) @map("team_id")
  teamName   String     @map("team_name") @db.VarChar(100)
  teamTag    String     @map("team_tag") @db.VarChar(10)
  ownerUserId BigInt    @map("owner_user_id")
  gameId     Int        @map("game_id")
  teamStatus TeamStatus @default(active) @map("team_status")
  logoUrl    String?    @map("logo_url") @db.VarChar(500)
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt  DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  owner        User                     @relation("TeamOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  game         Game                     @relation(fields: [gameId], references: [gameId], onDelete: Cascade)
  members      TeamMember[]
  participations TournamentParticipant[] @relation("TeamParticipant")

  @@unique([teamName, gameId], name: "unique_team_game")
  @@index([ownerUserId])
  @@index([gameId])
  @@map("teams")
}

model TeamMember {
  memberId   BigInt         @id @default(autoincrement()) @map("member_id")
  teamId     BigInt         @map("team_id")
  userId     BigInt         @map("user_id")
  memberRole TeamMemberRole @default(player) @map("member_role")
  joinedAt   DateTime       @default(now()) @map("joined_at") @db.Timestamp(0)

  team Team @relation(fields: [teamId], references: [teamId], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId], name: "unique_team_user")
  @@index([teamId])
  @@index([userId])
  @@map("team_members")
}

model Tournament {
  tournamentId      BigInt            @id @default(autoincrement()) @map("tournament_id")
  tournamentName    String            @map("tournament_name") @db.VarChar(200)
  tournamentSlug    String            @unique @map("tournament_slug") @db.VarChar(200)
  gameId            Int               @map("game_id")
  organizerId       BigInt            @map("organizer_id")
  tournamentType    TournamentType    @map("tournament_type")
  tournamentFormat  TournamentFormat  @default(single_elimination) @map("tournament_format")
  maxParticipants   Int               @map("max_participants")
  currentParticipants Int             @default(0) @map("current_participants")
  entryFee          Decimal           @default(0.00) @map("entry_fee") @db.Decimal(10, 2)
  prizePool         Decimal           @default(0.00) @map("prize_pool") @db.Decimal(12, 2)
  prizeDistribution Json?             @map("prize_distribution")
  tournamentStatus  TournamentStatus  @default(draft) @map("tournament_status")
  registrationStart DateTime?         @map("registration_start") @db.Timestamp(0)
  registrationEnd   DateTime?         @map("registration_end") @db.Timestamp(0)
  tournamentStart   DateTime?         @map("tournament_start") @db.Timestamp(0)
  tournamentEnd     DateTime?         @map("tournament_end") @db.Timestamp(0)
  rules             String?           @db.Text
  streamingEnabled  Boolean           @default(true) @map("streaming_enabled")
  bettingEnabled    Boolean           @default(false) @map("betting_enabled")
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt         DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  game         Game                     @relation(fields: [gameId], references: [gameId], onDelete: Cascade)
  organizer    User                     @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  participants TournamentParticipant[]
  matches      Match[]

  @@index([gameId])
  @@index([tournamentStatus])
  @@index([organizerId])
  @@index([registrationStart, registrationEnd])
  @@map("tournaments")
}

model TournamentParticipant {
  participantId      BigInt                  @id @default(autoincrement()) @map("participant_id")
  tournamentId       BigInt                  @map("tournament_id")
  userId             BigInt?                 @map("user_id")
  teamId             BigInt?                 @map("team_id")
  seedNumber         Int?                    @map("seed_number")
  registrationStatus ParticipantStatus       @default(pending) @map("registration_status")
  entryFeePaid       Boolean                 @default(false) @map("entry_fee_paid")
  registeredAt       DateTime                @default(now()) @map("registered_at") @db.Timestamp(0)

  tournament      Tournament  @relation(fields: [tournamentId], references: [tournamentId], onDelete: Cascade)
  user            User?       @relation("SoloParticipant", fields: [userId], references: [id], onDelete: Cascade)
  team            Team?       @relation("TeamParticipant", fields: [teamId], references: [teamId], onDelete: Cascade)
  matchesAsP1     Match[]     @relation("MatchParticipant1")
  matchesAsP2     Match[]     @relation("MatchParticipant2")
  matchesWon      Match[]     @relation("MatchWinner")
  betsOn          Bet[]
  odds            BettingOdds[]

  @@unique([tournamentId, userId], name: "unique_tournament_user")
  @@unique([tournamentId, teamId], name: "unique_tournament_team")
  @@index([tournamentId])
  @@index([registrationStatus])
  @@map("tournament_participants")
}

model Match {
  matchId        BigInt       @id @default(autoincrement()) @map("match_id")
  tournamentId   BigInt       @map("tournament_id")
  matchRound     String       @map("match_round") @db.VarChar(50)
  matchNumber    Int          @map("match_number")
  participant1Id BigInt?      @map("participant1_id")
  participant2Id BigInt?      @map("participant2_id")
  winnerId       BigInt?      @map("winner_id")
  matchStatus    MatchStatus  @default(scheduled) @map("match_status")
  scoreP1        Int          @default(0) @map("score_p1")
  scoreP2        Int          @default(0) @map("score_p2")
  scheduledTime  DateTime?    @map("scheduled_time") @db.Timestamp(0)
  startedAt      DateTime?    @map("started_at") @db.Timestamp(0)
  completedAt    DateTime?    @map("completed_at") @db.Timestamp(0)
  streamUrl      String?      @map("stream_url") @db.VarChar(500)
  replayUrl      String?      @map("replay_url") @db.VarChar(500)
  refereeId      BigInt?      @map("referee_id")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt      DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  tournament    Tournament             @relation(fields: [tournamentId], references: [tournamentId], onDelete: Cascade)
  participant1  TournamentParticipant? @relation("MatchParticipant1", fields: [participant1Id], references: [participantId], onDelete: SetNull)
  participant2  TournamentParticipant? @relation("MatchParticipant2", fields: [participant2Id], references: [participantId], onDelete: SetNull)
  winner        TournamentParticipant? @relation("MatchWinner", fields: [winnerId], references: [participantId], onDelete: SetNull)
  referee       User?                  @relation("MatchReferee", fields: [refereeId], references: [id], onDelete: SetNull)
  disputes      MatchDispute[]
  bets          Bet[]
  odds          BettingOdds[]
  streams       Stream[]

  @@index([tournamentId])
  @@index([matchStatus])
  @@index([scheduledTime])
  @@map("matches")
}

model MatchDispute {
  disputeId     BigInt        @id @default(autoincrement()) @map("dispute_id")
  matchId       BigInt        @map("match_id")
  reportedBy    BigInt        @map("reported_by")
  disputeReason String        @map("dispute_reason") @db.Text
  disputeStatus DisputeStatus @default(pending) @map("dispute_status")
  resolution    String?       @db.Text
  resolvedBy    BigInt?       @map("resolved_by")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamp(0)
  resolvedAt    DateTime?     @map("resolved_at") @db.Timestamp(0)

  match      Match @relation(fields: [matchId], references: [matchId], onDelete: Cascade)
  reporter   User  @relation("DisputeReporter", fields: [reportedBy], references: [id], onDelete: Cascade)
  resolver   User? @relation("DisputeResolver", fields: [resolvedBy], references: [id], onDelete: SetNull)

  @@index([matchId])
  @@index([disputeStatus])
  @@map("match_disputes")
}

model Wallet {
  walletId         BigInt       @id @default(autoincrement()) @map("wallet_id")
  userId           BigInt       @unique @map("user_id")
  balanceAvailable Decimal      @default(0.00) @map("balance_available") @db.Decimal(12, 2)
  balanceLocked    Decimal      @default(0.00) @map("balance_locked") @db.Decimal(12, 2)
  currencyCode     String       @default("USD") @map("currency_code") @db.Char(3)
  walletStatus     WalletStatus @default(active) @map("wallet_status")
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt        DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@index([walletStatus])
  @@map("wallets")
}

model WalletTransaction {
  transactionId     BigInt            @id @default(autoincrement()) @map("transaction_id")
  walletId          BigInt            @map("wallet_id")
  transactionType   TransactionType   @map("transaction_type")
  amount            Decimal           @map("amount") @db.Decimal(12, 2)
  balanceBefore     Decimal           @map("balance_before") @db.Decimal(12, 2)
  balanceAfter      Decimal           @map("balance_after") @db.Decimal(12, 2)
  referenceType     ReferenceType?    @map("reference_type")
  referenceId       BigInt?           @map("reference_id")
  paymentGateway    String?           @map("payment_gateway") @db.VarChar(50)
  paymentReference  String?           @map("payment_reference") @db.VarChar(255)
  transactionStatus TransactionStatus @default(pending) @map("transaction_status")
  notes             String?           @db.Text
  createdBy         BigInt?           @map("created_by")
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamp(0)

  wallet  Wallet @relation(fields: [walletId], references: [walletId], onDelete: Cascade)
  creator User?  @relation("TransactionCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([walletId])
  @@index([transactionType])
  @@index([transactionStatus])
  @@index([createdAt])
  @@map("wallet_transactions")
}

model Bet {
  betId               BigInt    @id @default(autoincrement()) @map("bet_id")
  userId              BigInt    @map("user_id")
  matchId             BigInt    @map("match_id")
  betType             BetType   @default(match_winner) @map("bet_type")
  betOnParticipantId  BigInt?   @map("bet_on_participant_id")
  betAmount           Decimal   @map("bet_amount") @db.Decimal(10, 2)
  odds                Decimal   @map("odds") @db.Decimal(8, 4)
  potentialPayout     Decimal   @map("potential_payout") @db.Decimal(12, 2)
  betStatus           BetStatus @default(pending) @map("bet_status")
  placedAt            DateTime  @default(now()) @map("placed_at") @db.Timestamp(0)
  settledAt           DateTime? @map("settled_at") @db.Timestamp(0)

  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  match       Match                  @relation(fields: [matchId], references: [matchId], onDelete: Cascade)
  participant TournamentParticipant? @relation(fields: [betOnParticipantId], references: [participantId], onDelete: SetNull)

  @@index([userId])
  @@index([matchId])
  @@index([betStatus])
  @@index([placedAt])
  @@map("bets")
}

model BettingOdds {
  oddsId        BigInt   @id @default(autoincrement()) @map("odds_id")
  matchId       BigInt   @map("match_id")
  participantId BigInt   @map("participant_id")
  oddsType      BetType  @default(match_winner) @map("odds_type")
  oddsValue     Decimal  @map("odds_value") @db.Decimal(8, 4)
  totalStaked   Decimal  @default(0.00) @map("total_staked") @db.Decimal(12, 2)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  match       Match                 @relation(fields: [matchId], references: [matchId], onDelete: Cascade)
  participant TournamentParticipant @relation(fields: [participantId], references: [participantId], onDelete: Cascade)

  @@index([matchId])
  @@index([isActive])
  @@map("betting_odds")
}

model Stream {
  streamId       BigInt       @id @default(autoincrement()) @map("stream_id")
  matchId        BigInt?      @map("match_id")
  streamerId     BigInt       @map("streamer_id")
  streamTitle    String       @map("stream_title") @db.VarChar(200)
  streamProvider String       @default("obs") @map("stream_provider") @db.VarChar(50)
  streamKey      String?      @map("stream_key") @db.VarChar(255)
  streamUrl      String?      @map("stream_url") @db.VarChar(500)
  playbackUrl    String?      @map("playback_url") @db.VarChar(500)
  streamStatus   StreamStatus @default(idle) @map("stream_status")
  viewerCount    Int          @default(0) @map("viewer_count")
  startedAt      DateTime?    @map("started_at") @db.Timestamp(0)
  endedAt        DateTime?    @map("ended_at") @db.Timestamp(0)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamp(0)

  match        Match?       @relation(fields: [matchId], references: [matchId], onDelete: SetNull)
  streamer     User         @relation(fields: [streamerId], references: [id], onDelete: Cascade)
  chatMessages StreamChat[]

  @@index([matchId])
  @@index([streamerId])
  @@index([streamStatus])
  @@map("streams")
}

model StreamChat {
  chatId    BigInt   @id @default(autoincrement()) @map("chat_id")
  streamId  BigInt   @map("stream_id")
  userId    BigInt   @map("user_id")
  message   String   @db.Text
  isDeleted Boolean  @default(false) @map("is_deleted")
  deletedBy BigInt?  @map("deleted_by")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  stream  Stream @relation(fields: [streamId], references: [streamId], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  deleter User?  @relation("ChatDeleter", fields: [deletedBy], references: [id], onDelete: SetNull)

  @@index([streamId])
  @@index([createdAt])
  @@map("stream_chat")
}

model AuditLog {
  logId      BigInt   @id @default(autoincrement()) @map("log_id")
  userId     BigInt?  @map("user_id")
  actionType String   @map("action_type") @db.VarChar(100)
  tableName  String?  @map("table_name") @db.VarChar(100)
  recordId   BigInt?  @map("record_id")
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  ipAddress  String   @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.Text
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([actionType])
  @@index([createdAt])
  @@map("audit_logs")
}

model SecurityEvent {
  eventId   BigInt            @id @default(autoincrement()) @map("event_id")
  eventType SecurityEventType @map("event_type")
  userId    BigInt?           @map("user_id")
  ipAddress String            @map("ip_address") @db.VarChar(45)
  severity  EventSeverity     @default(medium)
  details   Json?
  createdAt DateTime          @default(now()) @map("created_at") @db.Timestamp(0)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventType])
  @@index([severity])
  @@index([createdAt])
  @@map("security_events")
}

model RateLimit {
  limitId      BigInt    @id @default(autoincrement()) @map("limit_id")
  ipAddress    String    @map("ip_address") @db.VarChar(45)
  endpoint     String    @db.VarChar(255)
  requestCount Int       @default(1) @map("request_count")
  windowStart  DateTime  @default(now()) @map("window_start") @db.Timestamp(0)
  lockedUntil  DateTime? @map("locked_until") @db.Timestamp(0)

  @@unique([ipAddress, endpoint], name: "unique_ip_endpoint")
  @@index
  ([ipAddress])
@@index([lockedUntil])
@@map("rate_limits")
}
model SystemSetting {
settingId    Int          @id @default(autoincrement()) @map("setting_id")
settingKey   String       @unique @map("setting_key") @db.VarChar(100)
settingValue String       @map("setting_value") @db.Text
settingType  SettingType  @default(string) @map("setting_type")
isPublic     Boolean      @default(false) @map("is_public")
updatedAt    DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
updatedBy    BigInt?      @map("updated_by")
updater User? @relation(fields: [updatedBy], references: [id], onDelete: SetNull)
@@index([settingKey])
@@map("system_settings")
}
model FeatureFlag {
flagId            Int      @id @default(autoincrement()) @map("flag_id")
flagName          String   @unique @map("flag_name") @db.VarChar(100)
flagVersion       String   @map("flag_version") @db.VarChar(20)
isEnabled         Boolean  @default(false) @map("is_enabled")
rolloutPercentage Int      @default(0) @map("rollout_percentage")
updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
@@index([flagName])
@@index([isEnabled])
@@map("feature_flags")
}
enum UserType {
player
team
organizer
admin
}
enum AccountStatus {
active
suspended
banned
pending_verification
}
enum GameCategory {
sports
fps
moba
battle_royale
fighting
racing
strategy
}
enum TeamStatus {
active
disbanded
suspended
}
enum TeamMemberRole {
captain
player
substitute
}
enum TournamentType {
solo
team
}
enum TournamentFormat {
single_elimination
double_elimination
round_robin
swiss
}
enum TournamentStatus {
draft
registration
in_progress
completed
cancelled
}
enum ParticipantStatus {
pending
confirmed
withdrawn
disqualified
}
enum MatchStatus {
scheduled
live
completed
disputed
cancelled
}
enum DisputeStatus {
pending
under_review
resolved
rejected
}
enum WalletStatus {
active
frozen
suspended
}
enum TransactionType {
deposit
withdrawal
bet_placed
bet_won
bet_lost
bet_refund
tournament_entry
tournament_prize
tournament_refund
admin_adjustment
}
enum ReferenceType {
bet
tournament
payment
manual
}
enum TransactionStatus {
pending
completed
failed
reversed
}
enum BetType {
match_winner
score_prediction
handicap
over_under
}
enum BetStatus {
pending
won
lost
void
refunded
}
enum StreamStatus {
idle
live
ended
error
}
enum SecurityEventType {
failed_login
suspicious_activity
rate_limit_hit
account_locked
payment_fraud_detected
match_fixing_detected
}
enum EventSeverity {
low
medium
high
critical
}
enum SettingType {
string
int
float
bool
json
}
