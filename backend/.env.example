# ══════════════════════════════════════════
#  BETELITE Backend — Environment Variables
#  Copy this to .env and fill in your keys
# ══════════════════════════════════════════

# ── SERVER
PORT=3000
NODE_ENV=development

# ── ANTHROPIC (Claude AI for score detection)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY

# ── API-FOOTBALL (Real football scores — free tier)
# Get yours at: https://dashboard.api-football.com/register
API_FOOTBALL_KEY=REPLACE_WITH_YOUR_KEY

# ── FIREBASE (Real-time database + auth)
# Get from: Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=betelite-REPLACE
FIREBASE_DATABASE_URL=https://betelite-REPLACE-default-rtdb.firebaseio.com
# Paste your full service account JSON as a single line (or leave blank for demo mode)
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── CORS (comma-separated allowed origins)
CORS_ORIGINS=http://localhost:3000,https://okafordavis.github.io
